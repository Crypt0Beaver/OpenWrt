CONFIG_CCACHE=y

# Target
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_xiaomi_ax1800=y
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_8devices_mango-dvk is not set

# Wi-Fi standards
CONFIG_DRIVER_11AC_SUPPORT=y
CONFIG_DRIVER_11AX_SUPPORT=y

# Overall 256 MB IPQ memory profile
CONFIG_IPQ_MEM_PROFILE_256=y
# CONFIG_IPQ_MEM_PROFILE_512 is not set
# CONFIG_IPQ_MEM_PROFILE_1024 is not set

# ath11k 256 MB memory profile
CONFIG_ATH11K_MEM_PROFILE_256M=y
# CONFIG_ATH11K_MEM_PROFILE_512M is not set
# CONFIG_ATH11K_MEM_PROFILE_1G is not set

# Disable Wi-Fi NSS integration while retaining wired NSS
CONFIG_NSS_MEM_PROFILE_LOW=y
# CONFIG_NSS_MEM_PROFILE_MEDIUM is not set
# CONFIG_ATH11K_NSS_SUPPORT is not set
# CONFIG_ATH11K_NSS_MESH_SUPPORT is not set
# CONFIG_NSS_DRV_WIFIOFFLOAD_ENABLE is not set
# CONFIG_NSS_DRV_WIFI_MESH_ENABLE is not set
# CONFIG_PACKAGE_MAC80211_NSS_SUPPORT is not set
# CONFIG_PACKAGE_MAC80211_NSS_REDIRECT is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-wifi-meshmgr is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-wifioffload is not set
# CONFIG_PACKAGE_qca-nss-clients is not set
# CONFIG_PACKAGE_kmod-qca-nss-crypto is not set
# CONFIG_MAC80211_NSS_SUPPORT is not set


# Reduce memory/debug overhead
# CONFIG_ATH11K_DEBUGFS_STA is not set
# CONFIG_ATH11K_DEBUGFS_HTT_STATS is not set
# CONFIG_PACKAGE_MAC80211_DEBUGFS is not set
# CONFIG_KERNEL_DEBUG_INFO is not set

# Wi-Fi drivers and board data
CONFIG_PACKAGE_kmod-ath=y
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y
CONFIG_PACKAGE_ipq-wifi-xiaomi_ax1800=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_wifi-scripts=y

# WPA2/WPA3 access-point support
CONFIG_PACKAGE_wpad-basic-mbedtls=y

# LuCI web interface
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-app-commands=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y

# Networking and diagnostics
CONFIG_PACKAGE_umdns=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_htop=y

# Wired NSS firmware
CONFIG_PACKAGE_nss-firmware-ipq60xx=y

# Exclude unnecessary packages
# CONFIG_PACKAGE_coremark is not set
# CONFIG_PACKAGE_ddns-go is not set
# CONFIG_PACKAGE_luci-app-ddns-go is not set
# CONFIG_PACKAGE_luci-app-ttyd is not set
# CONFIG_PACKAGE_ttyd is not set
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_luci-theme-argon is not set
# CONFIG_PACKAGE_kmod-usb-storage is not set
# CONFIG_PACKAGE_block-mount is not set
# CONFIG_PACKAGE_avahi-daemon is not set
